<idea-plugin>
    <id>com.worklog</id>
    <name>WorkLog</name>
    <vendor email="sutao@linux.do" url="https://github.com/sutao1/workLogPlugin">WorkLog Plugin</vendor>

    <description><![CDATA[
    <p>
      WorkLog helps developers turn Git activity into daily work logs, AI summaries,
      code review reports, and periodic work reports directly inside IntelliJ-based IDEs.
    </p>

    <br/>
    <img src="https://raw.githubusercontent.com/sutao1/workLogPlugin/main/screenshots/worklog-tool-window.png"
         alt="WorkLog tool window" width="600" border="0"/>
    <br/><br/>

    <h2>Key features</h2>
    <ul>
      <li>Generate Markdown daily work logs from Git commits and optional local code changes.</li>
      <li>Create AI summaries through OpenAI-compatible or custom JSON API providers.</li>
      <li>Review staged changes before commit and review selected historical commits from Git Log.</li>
      <li>Browse, search, preview, and reopen saved work logs.</li>
      <li>Generate weekly, monthly, yearly, and custom range work reports from saved logs.</li>
      <li>Configure API providers, code access permission, review prompts, file filters, storage, and output templates.</li>
      <li>Export logs and review reports to Markdown, HTML, or PDF.</li>
    </ul>

    <h2>Workflow</h2>
    <ol>
      <li>Open the WorkLog tool window from the right sidebar.</li>
      <li>Select a date and generate a Markdown work log from Git history.</li>
      <li>Optionally enable AI API access to summarize commits and code changes.</li>
      <li>Use the code review actions before commit or from Git Log when you need an AI review report.</li>
      <li>Use Work Statistics to assemble weekly, monthly, yearly, or custom reports.</li>
    </ol>

    <h2>Screenshots</h2>
    <h3>AI code review result</h3>
    <img src="https://raw.githubusercontent.com/sutao1/workLogPlugin/main/screenshots/code-review-dialog.png"
         alt="AI code review result" width="600" border="0"/>
    <br/><br/>

    <h3>Work statistics and weekly report</h3>
    <img src="https://raw.githubusercontent.com/sutao1/workLogPlugin/main/screenshots/statistics-report.png"
         alt="Work statistics report" width="600" border="0"/>
    <br/><br/>

    <h3>History search and preview</h3>
    <img src="https://raw.githubusercontent.com/sutao1/workLogPlugin/main/screenshots/history-dialog.png"
         alt="History search and preview" width="600" border="0"/>
    <br/><br/>

    <h3>Settings</h3>
    <img src="https://raw.githubusercontent.com/sutao1/workLogPlugin/main/screenshots/settings-api-config-redacted.png"
         alt="AI API settings with redacted API key" width="600" border="0"/>
    ]]></description>

    <!-- Product and plugin compatibility requirements.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-compatibility.html -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <!-- Extension points defined by the plugin.
         Read more: https://plugins.jetbrains.com/docs/intellij/plugin-extension-points.html -->
    <extensions defaultExtensionNs="com.intellij">
        <!-- Tool Window -->
        <toolWindow id="WorkLog"
                    factoryClass="com.worklog.ui.WorkLogToolWindowFactory"
                    anchor="right"
                    icon="com.worklog.icons.WorkLogIcons.ToolWindow"/>

        <!-- Project Close Handler -->
        <projectCloseHandler implementation="com.worklog.listeners.ProjectCloseListener"/>

        <!-- Settings -->
        <applicationService serviceImplementation="com.worklog.settings.AppSettingsState"/>
        <projectConfigurable parentId="tools"
                           instance="com.worklog.settings.SettingsConfigurable"
                           id="com.worklog.settings.SettingsConfigurable"
                           displayName="WorkLog"/>

        <!-- Project Services -->
        <projectService serviceImplementation="com.worklog.services.GitService"/>
        <projectService serviceImplementation="com.worklog.services.WorkLogService"/>
        <projectService serviceImplementation="com.worklog.services.AIService"/>
        <projectService serviceImplementation="com.worklog.services.ReminderService"/>
        <projectService serviceImplementation="com.worklog.services.StatisticsService"/>
        <projectService serviceImplementation="com.worklog.services.CodeReviewService"/>
        <projectService serviceImplementation="com.worklog.services.PreCommitAutoReviewService"/>
        <projectService serviceImplementation="com.worklog.services.PreCommitHookService"/>

        <!-- Checkin Handler for Code Review -->
        <checkinHandlerFactory implementation="com.worklog.listeners.CodeReviewCheckinHandlerFactory"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Project Startup Activity -->
        <postStartupActivity implementation="com.worklog.listeners.ProjectStartupActivity"/>

        <!-- Notification Group -->
        <notificationGroup id="WorkLog Notifications" displayType="BALLOON"/>
    </extensions>

    <applicationListeners>
        <!-- IDE Shutdown Listener -->
        <listener class="com.worklog.listeners.AppCloseListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <actions>
        <!-- Main Actions -->
        <action id="com.worklog.actions.GenerateWorkLogAction"
                class="com.worklog.actions.GenerateWorkLogAction"
                text="生成工作日志"
                description="生成今日工作日志">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.ViewHistoryAction"
                class="com.worklog.actions.ViewHistoryAction"
                text="查看历史日志"
                description="查看历史工作日志">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.ViewStatisticsAction"
                class="com.worklog.actions.ViewStatisticsAction"
                text="工作统计"
                description="查看工作统计信息">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.GenerateWeeklyReportAction"
                class="com.worklog.actions.GenerateWeeklyReportAction"
                text="生成周报"
                description="生成本周工作周报">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.GenerateMonthlyReportAction"
                class="com.worklog.actions.GenerateMonthlyReportAction"
                text="生成月报"
                description="生成本月工作月报">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.GenerateYearlyReportAction"
                class="com.worklog.actions.GenerateYearlyReportAction"
                text="生成年报"
                description="生成年度工作总结报告">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.RunCodeReviewAction"
                class="com.worklog.actions.RunCodeReviewAction"
                text="代码评审"
                description="评审当前暂存区代码变更">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>

        <action id="com.worklog.actions.RunCommitHistoryReviewAction"
                class="com.worklog.actions.RunCommitHistoryReviewAction"
                text="评审提交代码"
                description="评审所选历史提交的代码变更">
            <add-to-group group-id="Vcs.Log.ContextMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
