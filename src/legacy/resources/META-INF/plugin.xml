<idea-plugin>
    <id>com.worklog</id>
    <name>WorkLog</name>
    <vendor email="sutao@linux.do" url="https://github.com/sutao1/workLogPlugin">WorkLog Plugin</vendor>

    <description><![CDATA[
    <h1>工作日志插件</h1>
    <p>一款工作日志管理插件，帮助开发者记录每日工作内容。</p>
    <p>这是面向较旧 IntelliJ IDEA 版本的兼容构建，保留核心 WorkLog 能力，弱化较新的提交区代码评审集成。</p>
    <p>兼容构建仍支持基础代码评审服务与结果预览，但不注册较新的提交工具栏、提交前拦截和历史提交工具栏集成。</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="WorkLog"
                    factoryClass="com.worklog.ui.WorkLogToolWindowFactory"
                    anchor="right"
                    icon="com.worklog.icons.WorkLogIcons.ToolWindow"/>

        <projectCloseHandler implementation="com.worklog.listeners.ProjectCloseListener"/>

        <applicationService serviceImplementation="com.worklog.settings.AppSettingsState"/>
        <projectConfigurable parentId="tools"
                           instance="com.worklog.settings.SettingsConfigurable"
                           id="com.worklog.settings.SettingsConfigurable"
                           displayName="WorkLog"/>

        <projectService serviceImplementation="com.worklog.services.GitService"/>
        <projectService serviceImplementation="com.worklog.services.WorkLogService"/>
        <projectService serviceImplementation="com.worklog.services.AIService"/>
        <projectService serviceImplementation="com.worklog.services.ReminderService"/>
        <projectService serviceImplementation="com.worklog.services.StatisticsService"/>
        <projectService serviceImplementation="com.worklog.services.CodeReviewService"/>
        <projectService serviceImplementation="com.worklog.services.PreCommitAutoReviewService"/>
        <projectService serviceImplementation="com.worklog.services.PreCommitHookService"/>
        <notificationGroup id="WorkLog Notifications" displayType="BALLOON" isLogByDefault="true"/>

        <action id="com.worklog.actions.RunCodeReviewAction"
                class="com.worklog.actions.RunCodeReviewAction"
                text="代码评审"
                description="评审当前暂存区代码变更">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.RunCommitHistoryReviewAction"
                class="com.worklog.actions.RunCommitHistoryReviewAction"
                text="评审提交代码"
                description="评审所选历史提交的代码变更">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </extensions>

    <applicationListeners>
        <listener class="com.worklog.listeners.AppCloseListener"
                  topic="com.intellij.ide.AppLifecycleListener"/>
        <listener class="com.worklog.listeners.LegacyProjectManagerListener"
                  topic="com.intellij.openapi.project.ProjectManagerListener"/>
    </applicationListeners>

    <actions>
        <action id="com.worklog.actions.GenerateWorkLogAction"
                class="com.worklog.actions.GenerateWorkLogAction"
                text="生成工作日志"
                description="生成今日工作日志">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.ViewHistoryAction"
                class="com.worklog.actions.ViewHistoryAction"
                text="查看历史日志"
                description="查看历史工作日志">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.ViewStatisticsAction"
                class="com.worklog.actions.ViewStatisticsAction"
                text="工作统计"
                description="查看工作统计信息">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.GenerateWeeklyReportAction"
                class="com.worklog.actions.GenerateWeeklyReportAction"
                text="生成周报"
                description="生成本周工作周报">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.GenerateMonthlyReportAction"
                class="com.worklog.actions.GenerateMonthlyReportAction"
                text="生成月报"
                description="生成本月工作月报">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="com.worklog.actions.GenerateYearlyReportAction"
                class="com.worklog.actions.GenerateYearlyReportAction"
                text="生成年报"
                description="生成年度工作总结报告">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
